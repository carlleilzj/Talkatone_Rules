# Talkatone 分流（业务）
# raw: https://raw.githubusercontent.com/carlleilzj/Talkatone_Rules/main/QuantumultX/Talkatone.list
# 策略组 Talkatone = 美国节点
#
# 重要: 务必让 Talkatone_Ads.list 排在本规则【上方】
# 本文件刻意不用过于宽泛的匹配去覆盖 lb-iad 广告子域；
# 下列为业务必需主机（比单纯 HOST-SUFFIX,tktn.be 更安全）

# 节点检测 / 中继
HOST-WILDCARD,relay-*.tktn.be,Talkatone

# XMPP 消息
HOST-WILDCARD,xmpp*.tktn.be,Talkatone
HOST-WILDCARD,xmpp-*.tktn.be,Talkatone

# API / 数据
HOST,a1.tktn.be,Talkatone
HOST,a2.tktn.be,Talkatone
HOST,d.tktn.be,Talkatone
HOST,d2.tktn.be,Talkatone
HOST,api.tktn.be,Talkatone
HOST,cnt.tktn.be,Talkatone

# 其余 tktn（登录等）；广告 lb-iad 由 Ads 列表关键字优先 reject
HOST-SUFFIX,tktn.at,Talkatone
HOST-SUFFIX,tktn.be,Talkatone

HOST-SUFFIX,vm.talkatone.com,Talkatone
HOST-SUFFIX,tenor.com,Talkatone
HOST,media.tenor.com,Talkatone
HOST,tenor.googleapis.com,Talkatone

# 直连（LOWERTOP）
HOST-SUFFIX,talkatone.com,direct
HOST-SUFFIX,talkamobile.com,direct
HOST-SUFFIX,agkn.com,direct
HOST-SUFFIX,cohere.com,direct
HOST-SUFFIX,crashlytics.com,direct
HOST-SUFFIX,inmobi.com,direct
HOST-SUFFIX,inner-active.mobi,direct
HOST-SUFFIX,ip-api.com,direct
HOST-SUFFIX,kochava.com,direct
HOST-SUFFIX,mobilefuse.com,direct

